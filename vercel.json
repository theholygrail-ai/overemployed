{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/[...path].mjs": {
      "maxDuration": 300
    },
    "api/hitl/[...segments].mjs": {
      "maxDuration": 300
    },
    "api/jobs/[id]/apply.mjs": {
      "maxDuration": 300
    },
    "api/jobs/[id]/live-frame.mjs": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    {
      "source": "/:path((?!api/|assets/|extension/).*)",
      "destination": "/index.html"
    }
  ]
}
