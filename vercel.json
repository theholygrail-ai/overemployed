{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/shim.mjs": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    { "source": "/api", "destination": "/api/shim?__p=" },
    { "source": "/api/", "destination": "/api/shim?__p=" },
    { "source": "/api/:path*", "destination": "/api/shim?__p=:path*" },
    { "source": "/", "destination": "/index.html" },
    {
      "source": "/:path((?!api/|assets/|extension/).*)",
      "destination": "/index.html"
    }
  ]
}
