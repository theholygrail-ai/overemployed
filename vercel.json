{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/[...path].mjs": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    {
      "source": "/:path((?!api/|assets/|extension/).*)",
      "destination": "/index.html"
    }
  ]
}
