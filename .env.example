# --- API server (EC2 / Docker) ---
GROQ_API_KEY=gsk_your_groq_api_key_here
# Optional: model for batch form-fill from tailored CV (defaults to openai/gpt-oss-120b)
# GROQ_APPLY_FILL_MODEL=openai/gpt-oss-120b

# Nova Act: Groq plans steps; Nova Act runs the browser (WSL on Windows dev, or Docker on servers).
# See https://nova.amazon.com/dev/documentation and https://github.com/amazon-agi-labs/nova-act-samples
# NOVA_ACT_API_KEY=          # from https://nova.amazon.com/act
# NOVA_ACT_MODEL_ID=nova-act-latest   # optional; SDK samples default; see AWS Nova Act user guide (model version selection)
# NOVA_ACT_GO_TO_URL_TIMEOUT=60       # optional; seconds for go_to_url (slow job sites)
# GROQ_NOVA_PLANNER_MODEL=openai/gpt-oss-120b
# NOVA_ACT_TIMEOUT_MS=1200000   # default 20 minutes
# NOVA_ACT_HEADLESS=true        # optional headless browser
#
# Docker runner (recommended on Linux/EC2 — build: docker compose --profile nova-act build nova-act):
# NOVA_ACT_USE_DOCKER=true
# NOVA_ACT_DOCKER_IMAGE=overemployed-nova-act:latest
# NOVA_ACT_HOST_DATA_PATH=/absolute/path/on/host/to/data   # same dir as compose ./data mount; required when API sees /app/data
# NOVA_ACT_DOCKER_BIN=docker
# Optional extra args as JSON array: NOVA_ACT_DOCKER_RUN_ARGS=["--network","host"]

# AWS: use IAM role on EC2, or keys for local dev
AWS_PROFILE=TheHolyGrail
AWS_REGION=eu-north-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Adzuna (optional)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# LinkedIn OAuth — callback MUST use your public API host in production
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:4900/api/auth/linkedin/callback

PORT=4900

# CORS: primary origin + optional comma-separated list (Express `cors` uses FRONTEND_URLS or FRONTEND_URL).
FRONTEND_URL=http://localhost:5200
# FRONTEND_URLS=https://your-app.vercel.app,http://localhost:5200

# Optional: protect POST /api/agents/run and POST /api/jobs/:id/apply
# Set the same value in Vercel as VITE_API_KEY
# API_KEY=

# Optional: limit POST/PATCH/PUT/DELETE per IP (express-rate-limit)
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_MAX=120
# RATE_LIMIT_WINDOW_MS=60000

# --- AWS serverless (Lambda + SAM) — see docs/DEPLOY-AWS-SERVERLESS.md ---
# DATA_S3_BUCKET=        # set automatically by SAM stack (S3 bucket)
# ORCHESTRATOR_FUNCTION_NAME=  # only on HTTP Lambda; worker name for async pipeline
# DYNAMODB_TABLE_NAME=TheHolyGrail-Applications
# ENABLE_NODE_CRON=false   # on Lambda; cron disabled (use EventBridge if needed)

# --- Vercel build (set in Vercel project settings; template: vercel.env.example) ---
# REQUIRED for production: without it, /api/* hits Vercel’s SPA (index.html) — sidebar looked "connected"
# (200 OK) but job list stayed empty because responses were HTML, not JSON.
# VITE_API_URL=https://xxxx.lambda-url.REGION.on.aws
# Remote API: WebSocket is not auto-derived unless you set VITE_WS_URL (sidebar uses "Live (API)" + GET /metrics).
# VITE_DISABLE_WS=true   # optional; forces no WS even in local dev
# VITE_WS_URL=wss://your-api-host.example.com/ws
# VITE_API_KEY=same_as_API_KEY_if_used
