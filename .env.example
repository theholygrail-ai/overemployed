# --- API server (EC2 / Docker) ---
GROQ_API_KEY=gsk_your_groq_api_key_here
# Optional: model for batch form-fill from tailored CV (defaults to openai/gpt-oss-120b)
# GROQ_APPLY_FILL_MODEL=openai/gpt-oss-120b

# --- Job apply automation (pick one path) ---
# Preferred: Browserbase cloud browser + Stagehand AI agent (see https://docs.browserbase.com , https://docs.stagehand.dev )
# BROWSERBASE_API_KEY=
# BROWSERBASE_PROJECT_ID=
# OPENAI_API_KEY=          # if STAGEHAND_MODEL is openai/… (default openai/gpt-4o)
# GROQ_API_KEY=            # if STAGEHAND_MODEL is groq/… e.g. groq/llama-3.3-70b-versatile
# STAGEHAND_MODEL=groq/llama-3.3-70b-versatile
# STAGEHAND_MODEL=openai/gpt-4o
# STAGEHAND_APPLY_MAX_STEPS=35
# STAGEHAND_NAV_TIMEOUT_MS=120000
# STAGEHAND_VERBOSE=0
# Live mirror + HITL pause (Browserbase): optional tuning
# BROWSERBASE_LIVE_FRAME_MS=2500
# BROWSERBASE_HITL_URL_REGEX=     # override default URL heuristics (JS RegExp source, case-insensitive)
# BROWSERBASE_HITL_TEXT_REGEX=    # override default page-text heuristics
# BROWSERBASE_HITL_MIN_CHECK_MS=5000
# BROWSERBASE_HITL_COOLDOWN_MS=60000
# BROWSERBASE_HITL_MAX_PAUSES=3
# BROWSERBASE_HITL_ACT_TIMEOUT_MS=720000

# Nova Act (AWS IAM, control plane us-east-1): register a workflow definition, then set its name here.
# https://docs.aws.amazon.com/nova-act/latest/userguide/interfaces.html
# https://github.com/amazon-agi-labs/nova-act-samples
# NOVA_ACT_WORKFLOW_DEFINITION_NAME=my-workflow
# NOVA_ACT_MODEL_ID=nova-act-latest
# If apply fails with NOT_FOUND / opaque resource id, ListModels picks a supported model automatically when the alias is wrong for your account.
# NOVA_ACT_API_KEY=   # optional Playground key only; production apply uses IAM
# NOVA_ACT_TIMEOUT_MS=1200000
# NOVA_ACT_HEADLESS=true
# NOVA_ACT_MAX_INVOKE_STEPS=400
# Retries when Nova returns NOT_FOUND (transient control-plane / propagation). Default 4.
# NOVA_ACT_NOT_FOUND_RETRIES=4
# CDP screencast → smooth MJPEG in UI (quality 1–100, min ms between frames ≈ 11fps at 85ms)
# NOVA_ACT_SCREENCAST_QUALITY=56
# NOVA_ACT_SCREENCAST_MIN_MS=85
# On Lambda only, allow in-process Playwright (custom image with Chromium): NOVA_ACT_ALLOW_LAMBDA_PLAYWRIGHT=true

# AWS: use IAM role on EC2, or keys for local dev
AWS_PROFILE=TheHolyGrail
AWS_REGION=eu-north-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Adzuna (optional)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# LinkedIn OAuth — callback MUST use your public API host in production
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:4900/api/auth/linkedin/callback

PORT=4900

# CORS: primary origin + optional comma-separated list (Express `cors` uses FRONTEND_URLS or FRONTEND_URL).
FRONTEND_URL=http://localhost:5200
# FRONTEND_URLS=https://your-app.vercel.app,http://localhost:5200

# Optional: protect POST /api/agents/run and POST /api/jobs/:id/apply
# Set the same value in Vercel as VITE_API_KEY
# API_KEY=

# Optional: limit POST/PATCH/PUT/DELETE per IP (express-rate-limit)
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_MAX=120
# RATE_LIMIT_WINDOW_MS=60000

# --- AWS serverless (Lambda + SAM) — see docs/DEPLOY-AWS-SERVERLESS.md ---
# DATA_S3_BUCKET=        # set automatically by SAM stack (S3 bucket)
# ORCHESTRATOR_FUNCTION_NAME=  # only on HTTP Lambda; worker name for async pipeline
# DYNAMODB_TABLE_NAME=TheHolyGrail-Applications
# ENABLE_NODE_CRON=false   # on Lambda; cron disabled (use EventBridge if needed)

# --- Vercel build (set in Vercel project settings; template: vercel.env.example) ---
# REQUIRED for production: without it, /api/* hits Vercel’s SPA (index.html) — sidebar looked "connected"
# (200 OK) but job list stayed empty because responses were HTML, not JSON.
# VITE_API_URL=https://xxxx.lambda-url.REGION.on.aws
# Remote API: WebSocket is not auto-derived unless you set VITE_WS_URL (sidebar uses "Live (API)" + GET /metrics).
# VITE_DISABLE_WS=true   # optional; forces no WS even in local dev
# VITE_WS_URL=wss://your-api-host.example.com/ws
# VITE_API_KEY=same_as_API_KEY_if_used
