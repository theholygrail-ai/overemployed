# =============================================================================
# Vercel — environment variables (frontend / Vite build)
# =============================================================================
# 1. Copy this file:  copy vercel.env.example vercel.env
# 2. Replace REPLACE_ME placeholders with your real values (no quotes needed).
# 3. Import into Vercel:
#    Dashboard → your project → Settings → Environment Variables
#    → "Import" / paste, or add each key manually.
# 4. Enable for Production (and Preview if you want previews to hit the API).
# 5. Redeploy so the build picks up VITE_* (they are baked in at build time).
#
# CLI (optional, after `vercel link`):
#   vercel env add VITE_API_URL production < vercel.env
#   (repeat per variable, or use dashboard import)
# =============================================================================

# Required in production: HTTPS origin of your API (no trailing slash).
# Example shapes: Lambda Function URL, API Gateway HTTP API, or custom domain.
VITE_API_URL=https://REPLACE_WITH_YOUR_API.execute-api.eu-north-1.amazonaws.com

# Lambda / API Gateway usually has no WebSocket — use REST polling in the UI.
VITE_DISABLE_WS=true

# Optional: only if you expose a WebSocket on your API host (not typical for Lambda URL).
# VITE_WS_URL=wss://your-api.example.com/ws

# Optional: same secret as server API_KEY on Lambda/EC2 when POST routes are protected.
# VITE_API_KEY=
