# Paste into Vercel → Project → Settings → Environment Variables (Production).
# Re-deploy the frontend after saving so Vite bakes VITE_* into the build.
#
# If you set a different VITE_API_URL in the Vercel dashboard, that value wins at build time;
# this file is documentation / default for new env imports.
#
# Replace the API URL with your HTTPS API when you terminate TLS in front of EC2
# (browsers block https:// Vercel → http:// EC2 due to mixed content).

VITE_API_URL=http://51.20.53.192:4900
VITE_DISABLE_WS=true
# Optional, if API_KEY is set on the server Secrets Manager / .env:
# VITE_API_KEY=
