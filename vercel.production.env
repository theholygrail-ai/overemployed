# Paste into Vercel → Project → Settings → Environment Variables (Production).
# Re-deploy after saving so Vite bakes VITE_* into the build.
#
# EC2 API is usually http:// — browsers block https:// Vercel → http:// EC2 (mixed content).
# Recommended: do NOT set VITE_API_URL; add BACKEND_URL (server-only) and let Vercel proxy /api.
#
# BACKEND_URL=http://YOUR_EC2_IP:4900
# VITE_DISABLE_WS=true
# VITE_API_KEY=   (optional, if API_KEY is set on the API)

VITE_DISABLE_WS=true
