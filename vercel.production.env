# Paste into Vercel → Project → Settings → Environment Variables (Production).
# Re-deploy after saving (VITE_* is baked at build; BACKEND_URL is read at runtime by api/[...path].mjs).
#
# EC2 API is usually http:// — browsers block https:// Vercel → http:// EC2 (mixed content).
# Required for the /api proxy: set ONE of these (server-side — do not use VITE_ prefix):
BACKEND_URL=http://51.20.53.192:4900
#
# Do not set VITE_API_URL when using the proxy (delete it in the dashboard if present).
# VITE_DISABLE_WS=true
# VITE_API_KEY=   (optional, if API_KEY is set on the API)

VITE_DISABLE_WS=true
