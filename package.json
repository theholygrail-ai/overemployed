{
  "name": "overemployed",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n frontend,backend -c cyan,magenta \"vite\" \"node server/index.js\"",
    "dev:frontend": "vite",
    "dev:backend": "node --watch server/index.js",
    "build": "npm run package:extension && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "package:extension": "node scripts/package-extension.js",
    "setup-aws": "node scripts/setup-aws.js",
    "sync:ec2-secrets": "node scripts/sync-ec2-secrets.mjs",
    "deploy:ec2-api": "node scripts/deploy-ec2-api.mjs",
    "ensure:nova-workflow": "node scripts/ensure-nova-workflow-definition.mjs",
    "deploy:vercel": "npx --yes vercel --prod",
    "build:aws": "sam build --template-file sam/template.yaml",
    "deploy:aws": "sam deploy --template-file sam/template.yaml --no-confirm-changeset --capabilities CAPABILITY_IAM --resolve-s3",
    "deploy:lambda": "powershell -ExecutionPolicy Bypass -File scripts/deploy-lambda-aws-cli.ps1",
    "probe:browserbase": "node scripts/probe-browserbase.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch-logs": "^3.1016.0",
    "@aws-sdk/client-dynamodb": "latest",
    "@aws-sdk/client-lambda": "^3.750.0",
    "@aws-sdk/client-nova-act": "^3.1016.0",
    "@aws-sdk/client-s3": "^3.750.0",
    "@aws-sdk/credential-providers": "latest",
    "@aws-sdk/lib-dynamodb": "latest",
    "@aws-sdk/s3-request-presigner": "^3.1016.0",
    "@browserbasehq/stagehand": "^3.2.0",
    "@codegenie/serverless-express": "^4.14.1",
    "axios": "latest",
    "cors": "latest",
    "deepmerge": "^4.3.1",
    "docx": "^9.6.1",
    "dotenv": "^16.4.7",
    "express": "latest",
    "express-rate-limit": "^8.3.1",
    "linkedin-jobs-scraper": "latest",
    "multer": "^2.1.1",
    "node-cron": "latest",
    "openai": "latest",
    "pdfkit": "^0.15.2",
    "playwright": "^1.58.2",
    "react": "latest",
    "react-dom": "latest",
    "react-native-web": "latest",
    "react-router-dom": "latest",
    "uuid": "latest",
    "ws": "latest",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "latest",
    "archiver": "^7.0.1",
    "concurrently": "latest",
    "supertest": "^7.2.2",
    "vite": "latest",
    "vite-plugin-react-native-web": "latest",
    "vitest": "^4.1.0"
  }
}
