{
  "name": "overemployed",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n frontend,backend -c cyan,magenta \"vite\" \"node server/index.js\"",
    "dev:frontend": "vite",
    "dev:backend": "node --watch server/index.js",
    "build": "vite build",
    "setup-aws": "node scripts/setup-aws.js",
    "deploy:vercel": "npx --yes vercel --prod",
    "build:aws": "sam build --template-file sam/template.yaml",
    "deploy:aws": "sam deploy --template-file sam/template.yaml --no-confirm-changeset --capabilities CAPABILITY_IAM --resolve-s3"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "latest",
    "@aws-sdk/client-lambda": "^3.750.0",
    "@aws-sdk/client-s3": "^3.750.0",
    "@aws-sdk/credential-providers": "latest",
    "@aws-sdk/lib-dynamodb": "latest",
    "@codegenie/serverless-express": "^4.14.1",
    "axios": "latest",
    "cors": "latest",
    "docx": "^9.6.1",
    "dotenv": "^16.4.7",
    "express": "latest",
    "linkedin-jobs-scraper": "latest",
    "multer": "^2.1.1",
    "node-cron": "latest",
    "openai": "latest",
    "playwright": "^1.58.2",
    "react": "latest",
    "react-dom": "latest",
    "react-native-web": "latest",
    "react-router-dom": "latest",
    "uuid": "latest",
    "ws": "latest"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "latest",
    "concurrently": "latest",
    "vite": "latest",
    "vite-plugin-react-native-web": "latest"
  }
}
